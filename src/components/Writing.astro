---
import { writing } from "../data/content";
import Icon from "./Icon.astro";
---

<section id="writing" class="py-10">
  <h2 class="section-title mb-3">Selected writing</h2>
  {
    writing.length > 0 && (
      <div class="flex flex-col gap-[10px]">
        {writing.map((entry) => (
          <a
            href={entry.url}
            target="_blank"
            rel="noopener noreferrer"
            class="block rounded-lg border border-border px-4 py-[14px] transition-colors hover:border-accent"
          >
            <p class="label-text mb-1 flex items-center gap-1">
              <Icon name="medium" size={14} aria-hidden={true} />
              Medium
            </p>
            <p class="card-title">{entry.title}</p>
            <p class="card-subtitle">{entry.excerpt}</p>
          </a>
        ))}
      </div>
    )
  }
</section>
