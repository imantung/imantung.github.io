---
import { linkedinPosts } from "../data/content";
---

<section id="posts" class="py-10">
  <h2 class="section-title mb-3">Featured LinkedIn posts</h2>
  {
    linkedinPosts.length > 0 && (
      <div class="flex flex-col gap-3">
        {linkedinPosts.map((post) => <Fragment set:html={post.embedCode} />)}
      </div>
    )
  }
</section>
