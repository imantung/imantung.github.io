---
import { experience, education } from "../data/content";
import Icon from "./Icon.astro";
---

<section id="experience" class="py-10">
  <h2 class="section-title mb-3">Experience</h2>
  <ul class="flex flex-col gap-[14px]">
    {
      experience.map((entry) => (
        <li class="flex flex-col justify-between gap-1 sm:flex-row sm:items-baseline sm:gap-4">
          <div>
            <p class="card-title">{entry.role}</p>
            <p class="card-subtitle">
              {entry.company}
              {entry.description && ` — ${entry.description}`}
            </p>
          </div>
          <span class="label-text whitespace-nowrap">{entry.period}</span>
        </li>
      ))
    }
  </ul>

  <div class="mt-4 border-t border-border pt-4">
    <div class="flex flex-col justify-between gap-1 sm:flex-row sm:items-baseline sm:gap-4">
      <div class="flex items-start gap-1.5">
        <Icon name="school" size={16} class="mt-0.5 shrink-0 text-muted" aria-hidden={true} />
        <p class="label-text">
          {education.degree} · {education.school}
        </p>
      </div>
      <span class="label-text whitespace-nowrap">{education.year}</span>
    </div>
  </div>
</section>
