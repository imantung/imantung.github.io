---
import { profile, socials } from "../data/content";
---

<section id="top" class="flex flex-col items-center pt-16 pb-12 text-center">
  <div class="mb-5 h-36 w-36 overflow-hidden rounded-full border border-border bg-surface">
    <img src="/profiles.png" alt={profile.name} class="h-full w-full object-cover" />
  </div>
  <h1 class="name-title">{profile.name}</h1>
  <p class="headline-text mt-4">{profile.headline}</p>
  <p class="meta-text mt-2 mb-6">{profile.location}</p>
  <div class="flex flex-col gap-[10px] sm:flex-row">
    <a href={`mailto:${profile.email}`} class="btn">Get in touch</a>
    <a href={socials.linkedin} target="_blank" rel="noopener noreferrer" class="btn">
      LinkedIn
    </a>
  </div>
</section>
